name = "kypost-push-relay-apns"
main = "src/index.ts"
compatibility_date = "2024-11-01"

# Persist the structured logs so send failures / rate-limit events are queryable
# in the dashboard (not just via a live `wrangler tail`).
[observability]
enabled = true

[vars]
# The per-minute limit is enforced by the PUSH_RATE_LIMITER binding below.
# RATE_LIMIT_PER_MINUTE here is display-only (/health + 429 body) and should be
# kept equal to that binding's simple.limit.
# NOTE: hour/day rolling limits were removed so an accepted send does zero KV
# writes (free-tier friendly). Restore them via Durable Objects on Workers Paid.
RATE_LIMIT_PER_MINUTE = "10"  # display only; keep equal to PUSH_RATE_LIMITER.simple.limit

# Public self-registration (POST /register). Self-hosted servers mint their own
# key with no maintainer involvement. Set to "false" to close registration if
# abused. Per-IP request rate is capped by the REGISTER_RATE_LIMITER binding
# below (independent of PUSH_RATE_LIMITER, which only governs /send).
REGISTRATION_ENABLED = "true"

# KV namespaces. Create these with:
#   npx wrangler kv namespace create API_KEYS
#   npx wrangler kv namespace create APNS_TOKEN_CACHE
# then paste the returned ids below. These MUST be distinct from the FCM worker's namespaces.
[[kv_namespaces]]
binding = "API_KEYS"
id = "REPLACE_WITH_API_KEYS_NAMESPACE_ID"

[[kv_namespaces]]
binding = "APNS_TOKEN_CACHE"
id = "REPLACE_WITH_APNS_TOKEN_CACHE_NAMESPACE_ID"

# Native per-key minute-tier rate limiter (no KV writes). period must be 10 or 60;
# namespace_id MUST be distinct from the FCM worker's (which uses 1001).
[[unsafe.bindings]]
name = "PUSH_RATE_LIMITER"
type = "ratelimit"
namespace_id = "1002"
simple = { limit = 10, period = 60 }

# Native per-IP minute-tier rate limiter for POST /register (no KV writes).
# namespace_id MUST be distinct from the FCM worker's (which uses 1003).
[[unsafe.bindings]]
name = "REGISTER_RATE_LIMITER"
type = "ratelimit"
namespace_id = "1004"
simple = { limit = 5, period = 60 }

# Analytics Engine dataset for per-key usage counters (off the KV write path).
# Query lifetime totals per key via the Analytics Engine SQL API. Created on deploy.
[[analytics_engine_datasets]]
binding = "USAGE_ANALYTICS"
dataset = "kypost_push_usage_apns"

# Secrets (set with `npx wrangler secret put <NAME>`, never commit them):
#   APNS_AUTH_KEY      - .p8 PEM private key contents from Apple Developer portal (preserve newlines)
#   APNS_KEY_ID        - Key ID from Apple Developer portal
#   APNS_TEAM_ID       - Team ID from Apple Developer portal
#   APNS_TOPIC         - Bundle ID, e.g. "com.urlxl.mail"
#   APNS_ENVIRONMENT   - "production" or "sandbox"
#   ADMIN_SECRET       - random secret guarding the /admin/keys endpoints
