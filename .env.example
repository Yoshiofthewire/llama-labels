OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODELS_HOST_DIR=./share/ollama/models

# Optional overrides
TUNING_FILE=/llama_lab/config/TUNING.md
TZ=America/New_York
# Public server URL used in the mobile pairing QR payload (for example https://my-domain.example)
SERVER_BASE_URL=

# Novu push notifications for the Android app (optional; leave blank to disable)
# NOVU_SECRET_KEY is a server-side secret — set the real value only in your local .env, never commit it
NOVU_SECRET_KEY=
NOVU_WORKFLOW_ID=
NOVU_APPLICATION_IDENTIFIER=
# Use https://eu.api.novu.co only for the EU region
NOVU_API_BASE=https://api.novu.co
