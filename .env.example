OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODELS_HOST_DIR=./share/ollama/models

# Optional overrides
TUNING_FILE=/llama_lab/config/TUNING.md
TZ=America/New_York
# Public server URL used in the mobile pairing QR payload (for example https://my-domain.example)
SERVER_BASE_URL=
# Required for native mobile pairing token signing/validation
PAIRING_SECRET=

# Native push relay (backend -> Cloudflare Worker -> FCM).
# The relay holds the single Firebase account the published app is built against,
# so self-hosters do not need their own Firebase credentials. See worker/README.md.
# Set PUSH_RELAY_URL and the server self-registers on first start (no operator
# involvement), persisting its key under SECRET_DIR. Leave PUSH_RELAY_KEY empty
# for that; only set it to pin a specific operator-issued key.
PUSH_RELAY_URL=
PUSH_RELAY_KEY=
# Optional: override where the auto-registered key is stored.
# Defaults to $SECRET_DIR/push_relay_key (a persistent volume in docker-compose).
PUSH_RELAY_KEY_FILE=
