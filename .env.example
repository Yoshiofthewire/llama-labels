OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODELS_HOST_DIR=./share/ollama/models

# Optional overrides
TUNING_FILE=/kypost/config/TUNING.md
TZ=America/New_York
# Public server URL used in the mobile pairing QR payload (for example https://my-domain.example)
SERVER_BASE_URL=
# Required for native mobile pairing token signing/validation
PAIRING_SECRET=

# The server trusts X-Forwarded-Proto/Host/For by default, assuming it runs
# behind a TLS-terminating reverse proxy that sets them. If you expose the
# container directly to clients (no proxy), set this to false so forged
# X-Forwarded-* headers can't influence scheme/host/client-IP decisions
# (cookie Secure flag, pairing URLs, login/DAV lockout keying).
#TRUST_PROXY_HEADERS=false

# Optional CAPTCHA on the login form (on top of the built-in 3-strikes/
# 15-minute account lockout). Leave CAPTCHA_PROVIDER unset to disable.
# CAPTCHA_PROVIDER=turnstile          # or: friendly
# CAPTCHA_SITE_KEY=                   # public site key, safe to expose to the frontend
# CAPTCHA_SECRET_KEY=                 # secret key, used server-side to verify solutions

# Break-glass MFA recovery: if every admin is locked out behind two-factor
# auth with no recovery codes, set this to clear TOTP/recovery codes/push-MFA
# for ALL users on the next restart. It does NOT turn itself off — it will
# keep clearing MFA on every boot until you unset it and restart again once
# users have re-enrolled.
#MFA_CLEAR_ALL=true

# Native push relay (Android, FCM) — backend -> Cloudflare Worker -> FCM.
# The relay holds the single Firebase account the published app is built against,
# so self-hosters do not need their own Firebase credentials. See worker/README.md.
# Set PUSH_RELAY_URL and the server self-registers on first start (no operator
# involvement), persisting its key under SECRET_DIR.
# Example (using the official KyPost relay):
PUSH_RELAY_URL=https://kypost-push-relay.urlxl.workers.dev

# Advanced PUSH_RELAY overrides (leave unset unless you know you need them):
#   PUSH_RELAY_KEY      Pin a specific operator-issued key and skip auto-registration.
#                       Needed if the relay operator issues you a key, or if multiple
#                       servers share one public IP (the relay allows one key per IP).
#   PUSH_RELAY_KEY_FILE Override where the auto-registered key is persisted.
#                       Defaults to $SECRET_DIR/push_relay_key (a persistent volume).
#PUSH_RELAY_KEY=
#PUSH_RELAY_KEY_FILE=

# Native push relay (iOS, APNs) — backend -> Cloudflare Worker -> APNs.
# The relay holds the APNs auth key (.p8) for the published app's bundle ID,
# so self-hosters do not need an Apple Developer account. See worker-apns/README.md.
# Set APNS_RELAY_URL and the server self-registers on first start (no operator
# involvement), persisting its key under SECRET_DIR.
# Example (using the official KyPost relay, currently running in APNs sandbox mode):
APNS_RELAY_URL=https://kypost-push-relay-apns.urlxl.workers.dev/

# Advanced APNS_RELAY overrides (leave unset unless you know you need them):
#   APNS_RELAY_KEY      Pin a specific operator-issued key and skip auto-registration.
#   APNS_RELAY_KEY_FILE Override where the auto-registered key is persisted.
#                       Defaults to $SECRET_DIR/apns_relay_key (a persistent volume).
#APNS_RELAY_KEY=
#APNS_RELAY_KEY_FILE=
